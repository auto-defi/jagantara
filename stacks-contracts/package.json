{
  "name": "jagantara-stacks-contracts",
  "version": "1.0.0",
  "description": "Jagantara - Decentralized Insurance on Stacks - Clarity Smart Contracts",
  "scripts": {
    "check": "clarinet check",
    "test": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:report": "npx vitest run --coverage",
    "test:fuzz": "clarinet fuzz",
    "test:all": "npm run test && npm run test:fuzz",
    "deploy:devnet": "clarinet deployments apply --devnet",
    "deploy:testnet": "clarinet deployments apply --testnet",
    "deploy:contracts": "npx tsx deploy-contracts.ts",
    "deploy": "npx tsx deploy-with-stacks.ts",
    "deploy:advanced": "npx tsx deploy-testnet-advanced.ts",
    "deploy:wallet": "npx tsx deploy-with-wallet-sdk.ts"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@stacks/clarinet-sdk": "^3.15.0",
    "@stacks/clarinet-sdk-wasm": "^3.15.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "bip39": "^3.1.0",
    "chokidar": "^3.5.3",
    "vitest": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "happy-dom": "^20.8.4",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "stacks",
    "clarity",
    "insurance",
    "dao",
    "jagantara"
  ],
  "author": "Jagantara Team",
  "license": "MIT"
}
